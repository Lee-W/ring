# ── gc ──
msgid ""
"usage: ring gc [--dry-run] [--older-than DURATION] [--all-ended]\n"
"\n"
"清理 RiNG 自己的 stale 狀態檔；不碰 Claude Code / Codex 的 transcript 或 state。\n"
"\n"
"options:\n"
"  --dry-run              只預覽，不刪檔\n"
"  --older-than DURATION  清理超過指定時間的已離場 registry（例如 30m、2h、7d；預設 7d）\n"
"  --all-ended            清理所有目前判定已離場的 registry\n"
msgstr ""
"usage: ring gc [--dry-run] [--older-than DURATION] [--all-ended]\n"
"\n"
"Clean RiNG's own stale state files; never touches Claude Code / Codex transcripts or state.\n"
"\n"
"options:\n"
"  --dry-run              preview only, delete nothing\n"
"  --older-than DURATION  remove ended registries older than DURATION (e.g. 30m, 2h, 7d; default 7d)\n"
"  --all-ended            remove every registry currently judged ended\n"

msgid "清理 RiNG 自己的 stale 狀態檔。"
msgstr "Clean RiNG's own stale state files."

msgid "只預覽，不刪檔"
msgstr "preview only, delete nothing"

msgid "清理超過指定時間的已離場 registry（例如 30m、2h、7d；預設 7d）"
msgstr "remove ended registries older than DURATION (e.g. 30m, 2h, 7d; default 7d)"

msgid "清理所有目前判定已離場的 registry"
msgstr "remove every registry currently judged ended"

msgid "無效的 --older-than：{value}"
msgstr "invalid --older-than: {value}"

msgid "RiNG GC：{action} {count} 個檔案"
msgstr "RiNG GC: {action} {count} file(s)"

msgid "將刪除"
msgstr "would delete"

msgid "已刪除"
msgstr "deleted"

msgid "將清掉"
msgstr "would clear"

msgid "已清掉"
msgstr "cleared"

msgid "隱藏清單：{action} {count} 筆過期／找不到的條目"
msgstr "Hidden list: {action} {count} stale/unreachable entr(y/ies)"

msgid "目前隱藏中：{count} 個 session"
msgstr "Currently hidden: {count} session(s)"

